// Valid Palindrome
function isPalindrome(str) {
    let left = 0;
    let right = str.length - 1;

    while (left < right) {
        if (str[left] !== str[right]) {
            return false;
        }
        left++;
        right--;
    }
    return true;
}

console.log(isPalindrome("racecar")); //Output: true


// Time Complexity ---> O(n)
// Space Complexity ---> O(1)
