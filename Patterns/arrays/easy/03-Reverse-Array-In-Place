//Reverse Array In-Place
 let arr =  [1, 2, 3, 4, 5]
// Output: [5, 4, 3, 2, 1]

let left = 0
let right = arr.length - 1
while (left < right) {
    [arr[left], arr[right]] = [arr[right], arr[left]];
    left ++
    right --
}

console.log(arr)
// Time Complexity ---> O(n)
// Space Complexity ---> O(1)
