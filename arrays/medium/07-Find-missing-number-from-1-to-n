// Find missing number from 1 to n
let arr = [1, 2, 4, 5, 6]
let n = 6
// Output: 3

function missingNumber(arr, n){
    let expectedSum = n*(n+1)/2 //formula to find the sum of first n natural numbers.
    let actualSum  = arr.reduce((acc, cur)=>acc+cur, 0)
    return expectedSum - actualSum
    // expectedSum → what sum should be
    // actualSum → what sum is
}
console.log(missingNumber(arr, n))

// Time Complexity --> O(n)
// Space Complexity --> O(n)
