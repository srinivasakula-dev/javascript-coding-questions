//Find pair with given sum
let arr = [1, 2, 3, 4, 5]
let sum = 7
// Output: [[2, 5], [3, 4]]

let res = []
let left = 0
let right = arr.length - 1
while(left < right){
    let k = arr[left] + arr[right]
    if(sum === k ){
        res.push([arr[left], arr[right]])
        left ++
        right --
    }else if(k < sum){
        left ++
    }else{
        right --
    }
}
console.log(res)
