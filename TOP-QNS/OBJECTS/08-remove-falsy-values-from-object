// Remove falsy values from object
let obj = {a:1, b:0, c:null, d:'hello'}
// Output: {a:1, d:'hello'}


// Remove ALL falsy values
let result = {}
for(let key in obj){
  if(obj[key]){
    result[key] = obj[key]
  }
}
console.log(result)


// Remove ONLY null/undefined

let result1 = {}
for(let key in obj){
  if(obj[key] != null){ // catches null + undefined only
    result1[key] = obj[key]
  }
}
console.log(result1)
