// Count frequency of values

let arr = ['a','b','a','c','b','a']
// Output: {a:3, b:2, c:1}

let result = {}
for(let chr of arr){
    result[chr] = (result[chr] || 0) + 1
}
console.log(result)

// Approach - 2 using reduce
const result1 = arr.reduce((acc, curr)=>{
    acc[curr] = (acc[curr] || 0) + 1
    return acc
}, {})

console.log(result1)
